{
  "name": "lol-build-advisor",
  "version": "0.3.0",
  "description": "LoL リアルタイムビルド提案デスクトップアプリ",
  "author": "299LLC",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && npx -y nodemon --watch electron -e js --exec electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:store": "vite build && electron-builder --win appx",
    "test:ai": "node test/harness/runner.js",
    "test:ai:bedrock": "node test/harness/runner.js --provider bedrock",
    "test:ai:anthropic": "node test/harness/runner.js --provider anthropic",
    "test:ai:verbose": "node test/harness/runner.js --verbose"
  },
  "dependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.59.0",
    "clsx": "^2.1.0",
    "league-connect": "^5.5.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "build": {
    "appId": "com.299llc.lol-sapo-kun",
    "productName": "ろるさぽくん",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "data/**/*"
    ],
    "win": {
      "target": [
        "portable",
        "appx"
      ],
      "icon": "build/icon.png"
    },
    "appx": {
      "identityName": "299LLC.LolSapoKun",
      "publisher": "CN=299LLC-TEST",
      "publisherDisplayName": "299LLC",
      "applicationId": "LolBuildAdvisor",
      "displayName": "ろるさぽくん",
      "languages": ["ja-JP"],
      "backgroundColor": "#010A13",
      "showNameOnTiles": false
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "tailwindcss": "^4.1.0",
    "vite": "^6.2.0",
    "wait-on": "^8.0.0"
  }
}
