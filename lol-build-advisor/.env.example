# ── モデル設定 ──
# CLAUDE_MODEL: macro/suggestion 用（高頻度、コスト重視）
# CLAUDE_QUALITY_MODEL: matchup/coaching 用（低頻度、品質重視）
# 未設定時はどちらも claude-haiku-4-5-20251001
# CLAUDE_MODEL=claude-3-haiku-20240307
# CLAUDE_QUALITY_MODEL=claude-haiku-4-5-20251001
#
# Gemini プロバイダー使用時（未設定時: gemini-2.5-flash）
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_QUALITY_MODEL=gemini-2.5-flash

# ── クラウドモード認証情報 ──

# 方式A: Anthropic API 直接（推奨）
ANTHROPIC_API_KEY=

# 方式B: Gemini API（Lambda Proxy 経由）
GEMINI_PROXY_URL=
GEMINI_APP_SECRET=

# 方式C: AWS Bedrock
# Bedrock APIキー
BEDROCK_API_KEY=
AWS_REGION=us-east-1

# Bedrock IAM認証（APIキーがない場合）
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
